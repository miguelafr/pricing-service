    {
      "name": "Test 1: Request at 10:00 on 14th June (PriceList 1)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/prices/active?applicationDate=2020-06-14T10:00:00Z&productId=35455&brandId=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "prices",
            "active"
          ],
          "query": [
            {
              "key": "applicationDate",
              "value": "2020-06-14T10:00:00Z"
            },
            {
              "key": "productId",
              "value": "35455"
            },
            {
              "key": "brandId",
              "value": "1"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Verify expected price details for Test 1', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.productId).to.eql(35455);",
              "    pm.expect(jsonData.brandId).to.eql(1);",
              "    pm.expect(jsonData.priceList).to.eql(1);",
              "    pm.expect(jsonData.price).to.eql(35.50);",
              "    pm.expect(jsonData.currency).to.eql('EUR');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
